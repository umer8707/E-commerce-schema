{
    "info": {
        "name": "E-commerce Cart API - Full Test Suite",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {"key": "base_url", "value": "http://127.0.0.1:8000"},
        {"key": "user_id", "value": ""},
        {"key": "user_id_2", "value": ""},
        {"key": "user_email", "value": ""},
        {"key": "user_email_2", "value": ""},
        {"key": "product_id", "value": ""},
        {"key": "product_id_2", "value": ""},
        {"key": "item_id", "value": ""},
        {"key": "item_id_2", "value": ""},
        {"key": "product_count_after_bulk", "value": "0"},
        {"key": "initial_shoes_stock", "value": "0"}
    ],
    "item": [
        {
            "name": "1 - Users",
            "item": [
                {
                    "name": "01 - Create User",
                    "event": [
                        {"listen": "prerequest", "script": {"exec": [
                            "pm.collectionVariables.set('user_email', 'user_' + Date.now() + '@test.com');"
                        ]}},
                        {"listen": "test", "script": {"exec": [
                            "pm.test('Status 201', () => pm.response.to.have.status(201));",
                            "pm.test('Returns id name email', () => {",
                            "    const d = pm.response.json();",
                            "    pm.expect(d).to.have.property('id');",
                            "    pm.expect(d).to.have.property('name');",
                            "    pm.expect(d).to.have.property('email');",
                            "});",
                            "pm.collectionVariables.set('user_id', pm.response.json().id);"
                        ]}}
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/users",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "{\"name\": \"Test User\", \"email\": \"{{user_email}}\"}"}
                    }
                },
                {
                    "name": "02 - Create User - Duplicate Email Rejected",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 400', () => pm.response.to.have.status(400));",
                        "pm.test('Already registered message', () => pm.expect(pm.response.json().detail.toLowerCase()).to.include('already registered'));"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/users",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "{\"name\": \"Other\", \"email\": \"{{user_email}}\"}"}
                    }
                },
                {
                    "name": "03 - Create User - Missing Name Rejected",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 422', () => pm.response.to.have.status(422));"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/users",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "{\"email\": \"nope@test.com\"}"}
                    }
                },
                {
                    "name": "04 - Create User - Missing Email Rejected",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 422', () => pm.response.to.have.status(422));"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/users",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "{\"name\": \"NoEmail\"}"}
                    }
                },
                {
                    "name": "05 - Create Second User",
                    "event": [
                        {"listen": "prerequest", "script": {"exec": [
                            "pm.collectionVariables.set('user_email_2', 'user2_' + Date.now() + '@test.com');"
                        ]}},
                        {"listen": "test", "script": {"exec": [
                            "pm.test('Status 201', () => pm.response.to.have.status(201));",
                            "pm.collectionVariables.set('user_id_2', pm.response.json().id);"
                        ]}}
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/users",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "{\"name\": \"User Two\", \"email\": \"{{user_email_2}}\"}"}
                    }
                },
                {
                    "name": "06 - Get User By ID",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 200', () => pm.response.to.have.status(200));",
                        "pm.test('Returns correct user', () => {",
                        "    const d = pm.response.json();",
                        "    pm.expect(d.id).to.eql(parseInt(pm.collectionVariables.get('user_id')));",
                        "    pm.expect(d).to.have.property('name');",
                        "    pm.expect(d).to.have.property('email');",
                        "});"
                    ]}}],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/users/{{user_id}}"
                    }
                },
                {
                    "name": "07 - Get User Not Found",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 404', () => pm.response.to.have.status(404));",
                        "pm.test('Not found message', () => pm.expect(pm.response.json().detail.toLowerCase()).to.include('not found'));"
                    ]}}],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/users/9999999"
                    }
                },
                {
                    "name": "08 - List Users",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 200', () => pm.response.to.have.status(200));",
                        "pm.test('Returns array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
                        "pm.test('Has at least 2 users', () => pm.expect(pm.response.json().data.length).to.be.gte(2));"
                    ]}}],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/users"
                    }
                }
            ]
        },
        {
            "name": "2 - Products",
            "item": [
                {
                    "name": "09 - Create Products Bulk",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 201', () => pm.response.to.have.status(201));",
                        "pm.test('Returns array of 2', () => pm.expect(pm.response.json()).to.have.lengthOf(2));",
                        "pm.test('First product has id', () => pm.expect(pm.response.json()[0]).to.have.property('id'));",
                        "pm.collectionVariables.set('product_id', pm.response.json()[0].id);",
                        "pm.collectionVariables.set('product_id_2', pm.response.json()[1].id);",
                        "pm.collectionVariables.set('initial_shoes_stock', pm.response.json()[0].stock);"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/products",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "[\n  {\"name\": \"Shoes\", \"price\": 49.99, \"stock\": 10},\n  {\"name\": \"Shirt\", \"price\": 19.99, \"stock\": 20}\n]"}
                    }
                },
                {
                    "name": "10 - List Products Non-Empty",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 200', () => pm.response.to.have.status(200));",
                        "pm.test('Returns array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
                        "pm.test('Has at least 2 products', () => pm.expect(pm.response.json().data.length).to.be.gte(2));",
                        "pm.collectionVariables.set('product_count_after_bulk', pm.response.json().total);"
                    ]}}],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/products"
                    }
                },
                {
                    "name": "11 - Create Single Product",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 201', () => pm.response.to.have.status(201));",
                        "pm.test('Correct name', () => pm.expect(pm.response.json()[0].name).to.eql('Cap'));",
                        "pm.test('Correct price', () => pm.expect(pm.response.json()[0].price).to.eql(9.99));",
                        "pm.test('Correct stock', () => pm.expect(pm.response.json()[0].stock).to.eql(5));"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/products",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "[{\"name\": \"Cap\", \"price\": 9.99, \"stock\": 5}]"}
                    }
                },
                {
                    "name": "12 - List Products Returns All",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 200', () => pm.response.to.have.status(200));",
                        "pm.test('Has one more product than before bulk', () => {",
                        "    const before = parseInt(pm.collectionVariables.get('product_count_after_bulk'));",
                        "    pm.expect(pm.response.json().total).to.eql(before + 1);",
                        "});"
                    ]}}],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/products"
                    }
                },
                {
                    "name": "13 - Create Product - Price Zero Rejected",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 422', () => pm.response.to.have.status(422));"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/products",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "[{\"name\": \"Free\", \"price\": 0, \"stock\": 5}]"}
                    }
                },
                {
                    "name": "14 - Create Product - Negative Price Rejected",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 422', () => pm.response.to.have.status(422));"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/products",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "[{\"name\": \"Bad\", \"price\": -10.0, \"stock\": 5}]"}
                    }
                },
                {
                    "name": "15 - Create Product - Negative Stock Rejected",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 422', () => pm.response.to.have.status(422));"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/products",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "[{\"name\": \"Bad\", \"price\": 10.0, \"stock\": -1}]"}
                    }
                },
                {
                    "name": "16 - Create Product - Missing Name Rejected",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 422', () => pm.response.to.have.status(422));"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/products",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "[{\"price\": 10.0, \"stock\": 5}]"}
                    }
                }
            ]
        },
        {
            "name": "3 - Cart Pre-Creation Errors",
            "item": [
