                        "pm.test('Not found message', () => pm.expect(pm.response.json().detail.toLowerCase()).to.include('not found'));"
                    ]}}],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/cart/{{user_id_2}}"
                    }
                },
                {
                    "name": "18 - Delete Cart Not Found",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 404', () => pm.response.to.have.status(404));"
                    ]}}],
                    "request": {
                        "method": "DELETE",
                        "url": "{{base_url}}/cart/{{user_id_2}}"
                    }
                },
                {
                    "name": "19 - Add Item - Cart Not Found",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 404', () => pm.response.to.have.status(404));",
                        "pm.test('Cart not found message', () => pm.expect(pm.response.json().detail.toLowerCase()).to.include('cart not found'));"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/cart/{{user_id_2}}/items",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "{\"product_id\": 1, \"quantity\": 1}"}
                    }
                },
                {
                    "name": "20 - Remove Item - Cart Not Found",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 404', () => pm.response.to.have.status(404));",
                        "pm.test('Cart not found message', () => pm.expect(pm.response.json().detail.toLowerCase()).to.include('cart not found'));"
                    ]}}],
                    "request": {
                        "method": "DELETE",
                        "url": "{{base_url}}/cart/{{user_id_2}}/items/1"
                    }
                },
                {
                    "name": "21 - Checkout - Cart Not Found",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 404', () => pm.response.to.have.status(404));",
                        "pm.test('Not found message', () => pm.expect(pm.response.json().detail.toLowerCase()).to.include('not found'));"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/cart/{{user_id_2}}/checkout"
                    }
                },
                {
                    "name": "22 - Create Cart - Nonexistent User Rejected",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 404', () => pm.response.to.have.status(404));",
                        "pm.test('User not found message', () => pm.expect(pm.response.json().detail.toLowerCase()).to.include('user not found'));"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/cart/9999999"
                    }
                }
            ]
        },
        {
            "name": "4 - Cart CRUD",
            "item": [
                {
                    "name": "23 - Create Cart",
                    "event": [
                        {"listen": "prerequest", "script": {"exec": [
                            "pm.sendRequest({ url: pm.collectionVariables.get('base_url') + '/cart/' + pm.collectionVariables.get('user_id'), method: 'DELETE' }, function() {});"
                        ]}},
                        {"listen": "test", "script": {"exec": [
                            "pm.test('Status 201', () => pm.response.to.have.status(201));",
                            "pm.test('Status is active', () => pm.expect(pm.response.json().status).to.eql('active'));",
                            "pm.test('Has id field', () => pm.expect(pm.response.json()).to.have.property('id'));",
                            "pm.test('Has user_id field', () => pm.expect(pm.response.json()).to.have.property('user_id'));"
                        ]}}
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/cart/{{user_id}}"
                    }
                },
                {
                    "name": "24 - Create Duplicate Cart Rejected",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 400', () => pm.response.to.have.status(400));",
                        "pm.test('Already exists message', () => pm.expect(pm.response.json().detail.toLowerCase()).to.include('already exists'));"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/cart/{{user_id}}"
                    }
                },
                {
                    "name": "25 - Get Empty Cart",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 200', () => pm.response.to.have.status(200));",
                        "pm.test('Has cart items total keys', () => {",
                        "    const d = pm.response.json();",
                        "    pm.expect(d).to.have.all.keys('cart', 'items', 'total');",
                        "});",
                        "pm.test('Items is empty', () => pm.expect(pm.response.json().items).to.eql([]));",
                        "pm.test('Total is zero', () => pm.expect(pm.response.json().total).to.eql(0));"
                    ]}}],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/cart/{{user_id}}"
                    }
                },
                {
                    "name": "26 - Cart Status Active On Creation",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 200', () => pm.response.to.have.status(200));",
                        "pm.test('Cart status is active', () => pm.expect(pm.response.json().cart.status).to.eql('active'));"
                    ]}}],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/cart/{{user_id}}"
                    }
                },
                {
                    "name": "27 - Delete Cart Success",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 204', () => pm.response.to.have.status(204));"
                    ]}}],
                    "request": {
                        "method": "DELETE",
                        "url": "{{base_url}}/cart/{{user_id}}"
                    }
                },
                {
                    "name": "28 - Get Deleted Cart Returns 404",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 404', () => pm.response.to.have.status(404));"
                    ]}}],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/cart/{{user_id}}"
                    }
                },
                {
                    "name": "29 - Recreate Cart After Delete",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 201', () => pm.response.to.have.status(201));",
                        "pm.test('New cart is active', () => pm.expect(pm.response.json().status).to.eql('active'));"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/cart/{{user_id}}"
                    }
                }
            ]
        },
        {
            "name": "5 - Cart Items",
            "item": [
                {
                    "name": "30 - Add Item Success",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 201', () => pm.response.to.have.status(201));",
                        "pm.test('Has all required fields', () => {",
                        "    const d = pm.response.json();",
                        "    pm.expect(d).to.have.all.keys('id', 'cart_id', 'product_id', 'product_name', 'quantity', 'price', 'subtotal');",
                        "});",
                        "pm.test('Quantity is 2', () => pm.expect(pm.response.json().quantity).to.eql(2));",
                        "pm.collectionVariables.set('item_id', pm.response.json().id);"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/cart/{{user_id}}/items",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "{\"product_id\": {{product_id}}, \"quantity\": 2}"}
                    }
                },
                {
                    "name": "31 - Add Second Product",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 201', () => pm.response.to.have.status(201));",
                        "pm.test('Subtotal equals price times quantity', () => {",
                        "    const d = pm.response.json();",
                        "    pm.expect(d.subtotal).to.eql(parseFloat((d.price * d.quantity).toFixed(2)));",
                        "});",
                        "pm.collectionVariables.set('item_id_2', pm.response.json().id);"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/cart/{{user_id}}/items",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "{\"product_id\": {{product_id_2}}, \"quantity\": 3}"}
                    }
                },
                {
                    "name": "32 - Get Cart With 2 Items",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 200', () => pm.response.to.have.status(200));",
                        "pm.test('Has 2 items', () => pm.expect(pm.response.json().items).to.have.lengthOf(2));"
                    ]}}],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/cart/{{user_id}}"
                    }
                },
                {
                    "name": "33 - Cart Total Matches Sum Of Subtotals",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 200', () => pm.response.to.have.status(200));",
                        "pm.test('Total is positive', () => pm.expect(pm.response.json().total).to.be.above(0));",
                        "pm.test('Total matches item sum', () => {",
                        "    const d = pm.response.json();",
                        "    const sum = parseFloat(d.items.reduce((acc, i) => acc + i.price * i.quantity, 0).toFixed(2));",
                        "    pm.expect(d.total).to.eql(sum);",
                        "});"
                    ]}}],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/cart/{{user_id}}"
                    }
                },
                {
                    "name": "34 - Add Same Product Merges Quantity",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 201', () => pm.response.to.have.status(201));",
                        "pm.test('Quantity merged to 5', () => pm.expect(pm.response.json().quantity).to.eql(5));"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/cart/{{user_id}}/items",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "{\"product_id\": {{product_id}}, \"quantity\": 3}"}
                    }
                },
                {
                    "name": "35 - Cart Still Has 2 Items After Merge",
                    "event": [{"listen": "test", "script": {"exec": [
                        "pm.test('Status 200', () => pm.response.to.have.status(200));",
                        "pm.test('Still 2 unique items', () => pm.expect(pm.response.json().items).to.have.lengthOf(2));",
                        "pm.test('Merged item has quantity 5', () => {",
                        "    const merged = pm.response.json().items.find(i => i.quantity === 5);",
                        "    pm.expect(merged).to.exist;",
                        "});"
                    ]}}],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/cart/{{user_id}}"
                    }
                },
