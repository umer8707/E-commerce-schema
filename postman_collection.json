                        "pm.test('Status 422', () => pm.response.to.have.status(422));"
                    ]}}],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/cart/{{user_id}}/items",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {"mode": "raw", "raw": "{\"quantity\": 1}"}
                    }
